# Required: your TeamDynamix organization's root URL.
# For a sandbox/preview instance this typically ends in teamdynamixpreview.com.
TEAMDYNAMIX_BASE_URL=https://demotemplate.teamdynamix.com

# --- Authentication: choose ONE of the following two methods ---

# Option A: standard user or service-account username/password login.
# Actions will appear in TeamDynamix as performed by this user.
TEAMDYNAMIX_USERNAME=
TEAMDYNAMIX_PASSWORD=

# Option B: admin service account login (key-based).
# Find BEID and WebServicesKey on TDAdmin's organization detail page.
# Requires the "Add BE Administrators" permission to set up, and the
# admin service account must be Active.
TEAMDYNAMIX_BEID=
TEAMDYNAMIX_WS_KEY=

# Optional: force which auth method to use if both are set ("user" or "admin").
# TEAMDYNAMIX_AUTH_METHOD=user

# Optional: transport. "stdio" (default) or "http".
# TRANSPORT=stdio
# PORT=3000
