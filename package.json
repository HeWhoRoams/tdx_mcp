{
  "name": "teamdynamix-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for the TeamDynamix Web API (tickets, assets/CIs, projects, issues, people/groups, reference data)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "teamdynamix-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "start:http": "TRANSPORT=http node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc && shx chmod +x dist/index.js",
    "clean": "rm -rf dist",
    "verify": "tsx scripts/verify-connection.ts",
    "list-apps": "tsx scripts/list-apps.ts",
    "search-tickets": "tsx scripts/search-tickets.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "shx": "^0.3.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
